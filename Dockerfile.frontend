# syntax=docker/dockerfile:1.7

# ─── Stage 1: build the Vite bundle ────────────────────────────────
FROM node:20-alpine AS build
WORKDIR /app

COPY package.json package-lock.json ./
RUN npm ci --no-audit --no-fund

COPY . .

# VITE_API_BASE can be overridden at build time; defaults to /api so the
# bundle's fetches go through nginx (which proxies /api to the backend).
ARG VITE_API_BASE=/api
ENV VITE_API_BASE=${VITE_API_BASE}
RUN npm run build

# ─── Stage 2: serve with nginx ─────────────────────────────────────
FROM nginx:alpine AS runtime
LABEL org.opencontainers.image.source="https://github.com/Amr-Khaled233/Docker-Task"
LABEL org.opencontainers.image.title="smilemaker-frontend"
LABEL org.opencontainers.image.description="SmileMaker Vite/React frontend served by nginx"

COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80

HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://localhost/ || exit 1

CMD ["nginx", "-g", "daemon off;"]
