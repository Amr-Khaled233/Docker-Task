# ─── Backend: Express API run with tsx ────────────────────────────
FROM node:20-alpine

WORKDIR /app

# Install dependencies (tsx is a devDependency, so install all)
COPY package.json package-lock.json ./
RUN npm ci

# Copy backend source
COPY tsconfig.json ./
COPY server ./server

ENV NODE_ENV=production
ENV PORT=3001
EXPOSE 3001

CMD ["npm", "run", "start"]
